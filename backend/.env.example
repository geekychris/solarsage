# SolarSage backend configuration. Copy to `.env` and edit.

# Where to store the SQLite history database
EG4_DB_PATH=./eg4_history.db

# EG4 Monitor base URL — the default works for most accounts
EG4_BASE_URL=https://monitor.eg4electronics.com

# Live-polling interval (seconds)
EG4_POLL_INTERVAL=60

# Set to "1" if your network intercepts TLS and breaks the cert chain
# (common on corp networks; harmless on a clean home network)
EG4_DISABLE_VERIFY_SSL=0

# Shared API key — required for X-API-Key auth on read endpoints, MCP, curl.
# The installer generates a unique value here; replace if you want your own.
EG4_API_KEY=local-dev-key-change-me

# Optional auto-login on backend start. If you tick "Remember me" in the UI,
# credentials are saved to backend/credentials.json (mode 0600) and these
# stay blank.
EG4_USERNAME=
EG4_PASSWORD=
